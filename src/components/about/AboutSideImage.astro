---
import building from "@images/building-2-min.jpg";
import { Image } from "astro:assets";

import { getLocaleFromUrl } from "@/js/localeUtils";
import { getLocalizedRoute, getTranslatedData, useTranslations } from "@/js/translationUtils";
const currLocale = getLocaleFromUrl(Astro.url);
const t = useTranslations(currLocale);

interface Props {
  class?: string;
}

const { class: className } = Astro.props as Props;
---

<section class:list={["py-16 md:py-24", className]}>
  <div class="site-container grid gap-8 md:grid-cols-2 md:gap-16">
    <div class="" id="about-side-image-trigger">
      <h2 data-mos="fade-up" class="h1">Chris Rotunno</h2>

      <div class="text-muted-foreground mt-6">
        <p
          class="md:text-lg"
          data-mos="fade-up"
          data-mos-anchor="#about-side-image-trigger"
          data-mos-delay=".2"
        >
          I'm a data analytics engineer and BI leader with a track record of building the full stack — from raw source tables to polished executive dashboards. My work lives at the intersection of engineering rigor and business clarity.
        </p>

        <p
          class="mt-6 md:text-lg"
          data-mos="fade-up"
          data-mos-anchor="#about-side-image-trigger"
          data-mos-delay=".4"
        >
          I've designed dimensional data warehouses, migrated legacy reporting to modern BI platforms, led teams of analysts and engineers, and built self-serve analytics that actually get used. I care as much about adoption as I do about accuracy.
        </p>

        <p
          class="mt-6 md:text-lg"
          data-mos="fade-up"
          data-mos-anchor="#about-side-image-trigger"
          data-mos-delay=".6"
        >
          Based in St. Augustine, FL. Open to remote-first roles and hybrid opportunities in Northeast Florida. Available for full-time positions and contract engagements.
        </p>
      </div>
    </div>

    <div class="aspect-square overflow-clip rounded-2xl">
      <Image
        src={building}
        alt="Chris Rotunno — Data Analytics Engineer"
        width={1001}
        densities={[1.5, 2]}
        class="h-full w-full object-cover"
      />
    </div>
  </div>
</section>
