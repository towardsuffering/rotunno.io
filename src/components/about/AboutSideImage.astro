---
import building from "@images/building-2-min.jpg";
import { Image } from "astro:assets";

import { getLocaleFromUrl } from "@/js/localeUtils";
import { getLocalizedRoute, getTranslatedData, useTranslations } from "@/js/translationUtils";
const currLocale = getLocaleFromUrl(Astro.url);
const t = useTranslations(currLocale);

interface Props {
  class?: string;
}

const { class: className } = Astro.props as Props;
---

<section class:list={["py-16 md:py-24", className]}>
  <div class="site-container grid gap-8 md:grid-cols-2 md:gap-16">
    <div class="" id="about-side-image-trigger">
      <h2 data-mos="fade-up" class="h1">Christopher A. Rotunno</h2>

      <div class="text-muted-foreground mt-6">
        <p
          class="md:text-lg"
          data-mos="fade-up"
          data-mos-anchor="#about-side-image-trigger"
          data-mos-delay=".2"
        >
          A decade across fintech, retail, and operations kept surfacing the same challenge from different angles: siloed systems, competing versions of truth, and people making decisions without enough visibility. The technical problem is usually solvable. The harder part is building something people actually trust — and that requires understanding the people as much as the data.
        </p>

        <p
          class="mt-6 md:text-lg"
          data-mos="fade-up"
          data-mos-anchor="#about-side-image-trigger"
          data-mos-delay=".4"
        >
          I've built pipelines, designed data models, led small engineering teams, and shipped dashboards from scratch. But the work I'm most proud of isn't the infrastructure — it's the moment a stakeholder stops asking "can you pull that for me?" because the answer is already in front of them. I care as much about adoption as I do about accuracy.
        </p>

        <p
          class="mt-6 md:text-lg"
          data-mos="fade-up"
          data-mos-anchor="#about-side-image-trigger"
          data-mos-delay=".6"
        >
          I work best alongside people who care as much about how something gets built as what gets built — implementers, challengers, and collaborators who push the work forward. Based in St. Augustine, FL. Open to remote-first roles and hybrid opportunities in Northeast Florida.
        </p>
      </div>
    </div>

    <div class="aspect-square overflow-clip rounded-2xl">
      <Image
        src={building}
        alt="Christopher A. Rotunno — Data Analytics Engineer"
        width={1001}
        densities={[1.5, 2]}
        class="h-full w-full object-cover"
      />
    </div>
  </div>
</section>
