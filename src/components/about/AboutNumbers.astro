---
import { getLocaleFromUrl } from "@/js/localeUtils";
import { getLocalizedRoute, getTranslatedData, useTranslations } from "@/js/translationUtils";

const currLocale = getLocaleFromUrl(Astro.url);
const t = useTranslations(currLocale);

interface StatItem {
  value: string;
  label: string;
}

const stats: StatItem[] = [
  {
    value: "2",
    label: "Founders",
  },
  {
    value: "1",
    label: "Signature Drink",
  },
  {
    value: "100+",
    label: "Events This Year",
  },
  {
    value: "∞",
    label: "Satisfied Customers",
  },
];
---

<section class="relative overflow-hidden px-4 py-12 md:py-16">
  <div class="site-container relative overflow-hidden rounded-xl py-6 md:rounded-2xl md:py-12">
    <div class="absolute inset-0 z-0 bg-gradient-to-r from-primary-700 to-primary-500 dark:from-primary-900 dark:to-primary-700"></div>
    <div class="site-container relative z-10">
      <div
        id="about-numbers-trigger"
        class="md:divide-base-200 grid grid-cols-2 gap-6 text-center md:grid-cols-4 md:gap-0 md:divide-x"
      >
        {
          stats.map((stat, index) => (
            <div
              class="font-heading space-y-1.5 py-10 font-semibold md:px-4"
              data-mos="fade-up"
              data-mos-anchor="#about-numbers-trigger"
              data-mos-delay={index * 0.15}
            >
              <p class="stat-number text-base-50 text-5xl md:text-6xl">{stat.value}</p>
              <p class="text-base-50 text-lg md:text-xl">{stat.label}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .stat-number {
    display: inline-block;
  }
</style>

<script>
  const CHARS = '0123456789';

  function spinToValue(el: HTMLElement) {
    const final = el.dataset.final!;
    let frame = 0;
    const totalFrames = 18;

    function next() {
      frame++;
      const progress = frame / totalFrames;
      // slow down as we approach end
      const delay = 20 + Math.pow(progress, 2) * 140;

      if (frame < totalFrames) {
        // show random chars
        el.textContent = final.replace(/[0-9]/g, () =>
          CHARS[Math.floor(Math.random() * CHARS.length)]
        ).replace(/∞/, () =>
          CHARS[Math.floor(Math.random() * CHARS.length)]
        );
        setTimeout(next, delay);
      } else {
        el.textContent = final;
      }
    }
    next();
  }

  function initSpinNumbers() {
    const numbers = document.querySelectorAll<HTMLElement>('.stat-number');

    numbers.forEach(el => {
      el.dataset.final = el.textContent ?? '';
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          setTimeout(() => spinToValue(entry.target as HTMLElement), i * 150);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.4 });

    numbers.forEach(n => observer.observe(n));
  }

  initSpinNumbers();
  document.addEventListener('astro:after-swap', initSpinNumbers);
</script>
