---
import cardBg from "@images/card_bg-min.jpg";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

import { getLocaleFromUrl } from "@/js/localeUtils";

const currLocale = getLocaleFromUrl(Astro.url);

const aboutCardsData = [
  {
    title: "Data Pipeline Engineering",
    description:
      "I build the infrastructure that makes analytics reliable — ETL/ELT pipelines in Python, SQL-based transformation layers, RESTful API integrations, and high-availability data systems. Clean data in, trustworthy metrics out.",
    icon: "tabler/database",
  },
  {
    title: "Analytics & Visualization",
    description:
      "I design dashboards people actually use. Working primarily in Tableau, I focus on the right KPIs, clean visual hierarchy, and layouts that reduce ad-hoc requests and increase data literacy across teams.",
    icon: "tabler/chart-bar",
  },
  {
    title: "Team & Technical Leadership",
    description:
      "I've led engineering teams from the ground up, defined data standards, and translated complex systems into clear business decisions. I communicate findings in plain language and build systems that support the people using them.",
    icon: "tabler/users",
  },
];
---

<section id="about-side-cards" class="my-12 py-12">
  <div class="site-container mt-12 grid gap-8 lg:grid-cols-2 lg:gap-20">
    <div
      class="relative flex aspect-7/8 items-center justify-center rounded-2xl p-6 pt-20 md:px-10"
      data-mos="fade-right"
    >
      <div class="bg-primary absolute inset-0 h-full w-full overflow-hidden rounded-xl">
        <Image
          src={cardBg}
          alt="Data analytics background"
          width={500}
          densities={[1.5, 2]}
          class="h-full w-full object-cover mix-blend-overlay"
        />
      </div>

      <div class="text-muted relative mb-auto flex flex-col items-center text-center">
        <div>
          <h2 class="h1 text-pretty text-white">What I Bring to Every Data Role</h2>
        </div>
      </div>
    </div>

    <div class="flex flex-col justify-between gap-8 md:py-10" data-mos="fade-left">
      {
        aboutCardsData.map((card) => (
          <div class="">
            <div class="flex items-center gap-4">
              <div class="shrink-0">
                <Icon name={card.icon} class="text-primary-accent size-14" />
              </div>
              <div>
                <h3 class="h2">{card.title}</h3>
              </div>
            </div>
            <p class="text-muted-foreground mt-4 md:text-lg">{card.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
