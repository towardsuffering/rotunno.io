---
import Button from "@/components/button/Button.astro";
import { Checkbox } from "@/components/starwind/checkbox";
import { Input } from "@/components/starwind/input";
import { Label } from "@/components/starwind/label";
import {
  Select,
  SelectContent,
  SelectGroup,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/starwind/select";
import { Textarea } from "@/components/starwind/textarea";
---

<div id="form-success" class="hidden rounded-xl border border-green-500/30 bg-green-500/10 px-6 py-8 text-center">
  <div class="mb-3 text-4xl">✅</div>
  <h3 class="font-heading mb-2 text-xl font-semibold text-green-600 dark:text-green-400">Message Sent!</h3>
  <p class="text-muted-foreground">Thanks for reaching out — I'll get back to you within one business day.</p>
</div>

<div id="form-error" class="hidden rounded-xl border border-red-500/30 bg-red-500/10 px-6 py-4 text-center">
  <p class="text-sm text-red-600 dark:text-red-400">Something went wrong. Please try again or email me at <a href="mailto:chrisrotunno@icloud.com" class="underline">chrisrotunno@icloud.com</a>.</p>
</div>

<form
  id="contact-form"
  name="contact"
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  class="@container flex flex-col gap-6"
>
  <input type="hidden" name="form-name" value="contact" />
  <p class="hidden"><input name="bot-field" /></p>

  <div class="grid gap-6 @md:grid-cols-2">
    <div class="flex flex-col gap-1.5">
      <Label for="full-name">Full Name</Label>
      <Input id="full-name" type="text" name="full-name" class="min-h-12 px-4 py-3" placeholder="Ray Dalio" required />
    </div>
    <div class="flex flex-col gap-1.5">
      <Label for="email">Email Address</Label>
      <Input id="email" type="email" name="email" class="min-h-12 px-4 py-3" placeholder="ray@bridgewater.com" required />
    </div>
  </div>

  <div class="grid gap-6 @md:grid-cols-2">
    <div class="flex flex-col gap-1.5">
      <Label for="phone">Phone Number</Label>
      <Input id="phone" type="tel" name="phone" class="min-h-12 px-4 py-3" placeholder="(203) 555-0191" />
    </div>
    <div class="flex flex-col gap-1.5">
      <Label for="reason">Type of Inquiry</Label>
      <Select id="reason" name="reason">
        <SelectTrigger class="min-h-12 w-full px-4 py-3">
          <SelectValue placeholder="Select a reason" />
        </SelectTrigger>
        <SelectContent>
          <SelectGroup>
            <SelectItem value="full-time">Full-Time Role</SelectItem>
            <SelectItem value="contract">Contract / Consulting</SelectItem>
            <SelectItem value="collaboration">Collaboration / Partnership</SelectItem>
            <SelectItem value="general">General Question</SelectItem>
          </SelectGroup>
        </SelectContent>
      </Select>
    </div>
  </div>

  <div class="flex flex-col gap-1.5">
    <Label for="message">Your Message</Label>
    <Textarea id="message" name="message" class="min-h-12 px-4 py-3" placeholder="Chris — we're deep in a long-term debt cycle deleveraging and most of our analysts are still pattern-matching off the short-term cycle. I need data systems that can model both, surface the signal from the noise, and help me figure out whose opinions are actually worth weighting. Believability isn't a gut call — it should be in the data. Can you build that?" rows={4} required />
  </div>

  <div class="flex gap-2">
    <Checkbox id="consent" variant="primary" name="consent" />
    <label for="consent" class="text-sm cursor-pointer">I consent to having this website store my submitted information</label>
  </div>

  <Button variant="primary" type="submit" id="submit-btn" class="w-full py-3 text-lg">
    Send Message
  </Button>
</form>

<script>
  function initContactForm() {
    const form = document.querySelector("#contact-form") as HTMLFormElement | null;
    const successMsg = document.querySelector("#form-success") as HTMLElement | null;
    const errorMsg = document.querySelector("#form-error") as HTMLElement | null;
    const submitBtn = document.querySelector("#submit-btn") as HTMLButtonElement | null;

    if (!form) return;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = "Sending…";
      }
      errorMsg?.classList.add("hidden");

      try {
        const body = new URLSearchParams(new FormData(form) as any).toString();
        const res = await fetch("/", {
          method: "POST",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body,
        });

        if (res.ok) {
          form.classList.add("hidden");
          successMsg?.classList.remove("hidden");
        } else {
          throw new Error(String(res.status));
        }
      } catch {
        errorMsg?.classList.remove("hidden");
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = "Send Message";
        }
      }
    });
  }

  initContactForm();
  document.addEventListener("astro:after-swap", initContactForm);
</script>
