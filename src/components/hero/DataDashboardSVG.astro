---
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 400 500"
  class="h-full w-auto"
  aria-hidden="true"
>
  <defs>
    <linearGradient id="card-bg" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#1e3a5f" />
      <stop offset="100%" stop-color="#0f1f38" />
    </linearGradient>
    <linearGradient id="bar1" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#38bdf8" />
      <stop offset="100%" stop-color="#0ea5e9" />
    </linearGradient>
    <linearGradient id="bar2" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#818cf8" />
      <stop offset="100%" stop-color="#6366f1" />
    </linearGradient>
    <linearGradient id="bar3" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#34d399" />
      <stop offset="100%" stop-color="#10b981" />
    </linearGradient>
    <filter id="card-shadow">
      <feDropShadow dx="0" dy="16" stdDeviation="24" flood-color="#000" flood-opacity="0.45" />
    </filter>
    <filter id="glow-blue">
      <feDropShadow dx="0" dy="0" stdDeviation="6" flood-color="#38bdf8" flood-opacity="0.6" />
    </filter>
    <clipPath id="card-clip">
      <rect x="30" y="60" width="340" height="390" rx="16" />
    </clipPath>
  </defs>

  <style>
    .card-float {
      animation: float 6s ease-in-out infinite;
    }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50%       { transform: translateY(-12px); }
    }
    .bar-1 { animation: grow-bar 2s ease-out 0.2s both; transform-origin: bottom; transform-box: fill-box; }
    .bar-2 { animation: grow-bar 2s ease-out 0.45s both; transform-origin: bottom; transform-box: fill-box; }
    .bar-3 { animation: grow-bar 2s ease-out 0.7s both; transform-origin: bottom; transform-box: fill-box; }
    .bar-4 { animation: grow-bar 2s ease-out 0.55s both; transform-origin: bottom; transform-box: fill-box; }
    .bar-5 { animation: grow-bar 2s ease-out 0.35s both; transform-origin: bottom; transform-box: fill-box; }
    .bar-6 { animation: grow-bar 2s ease-out 0.8s both; transform-origin: bottom; transform-box: fill-box; }
    @keyframes grow-bar {
      from { transform: scaleY(0); }
      to   { transform: scaleY(1); }
    }
    .line-draw {
      stroke-dasharray: 260;
      stroke-dashoffset: 260;
      animation: draw 2.2s ease-out 0.8s both;
    }
    @keyframes draw {
      to { stroke-dashoffset: 0; }
    }
    .kpi-fade { animation: fade-in 1s ease-out 1.2s both; }
    .dot-pulse {
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; r: 5; }
      50%       { opacity: 0.6; r: 7; }
    }
    @keyframes fade-in {
      from { opacity: 0; transform: translateY(4px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>

  <g class="card-float" filter="url(#card-shadow)">
    <!-- Dashboard card -->
    <rect x="30" y="60" width="340" height="390" rx="16" fill="url(#card-bg)" />
    <rect x="30" y="60" width="340" height="390" rx="16" fill="none" stroke="#334155" stroke-width="1.5" />

    <!-- Top bar -->
    <rect x="30" y="60" width="340" height="44" rx="16" fill="#162032" />
    <rect x="30" y="88" width="340" height="16" fill="#162032" />
    <!-- Dots -->
    <circle cx="58" cy="82" r="5" fill="#ef4444" />
    <circle cx="75" cy="82" r="5" fill="#f59e0b" />
    <circle cx="92" cy="82" r="5" fill="#22c55e" />
    <!-- Title -->
    <rect x="154" y="76" width="82" height="12" rx="4" fill="#334155" />

    <!-- KPI boxes row -->
    <g class="kpi-fade">
      <!-- KPI 1 -->
      <rect x="48" y="122" width="88" height="56" rx="8" fill="#162032" stroke="#1e3a5f" stroke-width="1" />
      <text x="92" y="145" text-anchor="middle" fill="#38bdf8" font-size="14" font-family="system-ui,sans-serif" font-weight="700">$2.4M</text>
      <text x="92" y="162" text-anchor="middle" fill="#64748b" font-size="9" font-family="system-ui,sans-serif">Revenue</text>

      <!-- KPI 2 -->
      <rect x="156" y="122" width="88" height="56" rx="8" fill="#162032" stroke="#1e3a5f" stroke-width="1" />
      <text x="200" y="145" text-anchor="middle" fill="#34d399" font-size="14" font-family="system-ui,sans-serif" font-weight="700">94.2%</text>
      <text x="200" y="162" text-anchor="middle" fill="#64748b" font-size="9" font-family="system-ui,sans-serif">Accuracy</text>

      <!-- KPI 3 -->
      <rect x="264" y="122" width="88" height="56" rx="8" fill="#162032" stroke="#1e3a5f" stroke-width="1" />
      <text x="308" y="145" text-anchor="middle" fill="#818cf8" font-size="14" font-family="system-ui,sans-serif" font-weight="700">↑ 18%</text>
      <text x="308" y="162" text-anchor="middle" fill="#64748b" font-size="9" font-family="system-ui,sans-serif">YoY Growth</text>
    </g>

    <!-- Bar chart area -->
    <rect x="48" y="195" width="148" height="130" rx="6" fill="#0f1a2e" />
    <text x="56" y="211" fill="#64748b" font-size="8" font-family="system-ui,sans-serif">Monthly Revenue</text>
    <!-- Bars -->
    <rect class="bar-1" x="61"  y="267" width="14" height="48" rx="3" fill="url(#bar1)" />
    <rect class="bar-2" x="81"  y="254" width="14" height="61" rx="3" fill="url(#bar1)" />
    <rect class="bar-3" x="101" y="276" width="14" height="39" rx="3" fill="url(#bar1)" />
    <rect class="bar-4" x="121" y="248" width="14" height="67" rx="3" fill="url(#bar2)" />
    <rect class="bar-5" x="141" y="258" width="14" height="57" rx="3" fill="url(#bar2)" />
    <rect class="bar-6" x="161" y="236" width="14" height="79" rx="3" fill="url(#bar1)" opacity="0.9" />
    <!-- Baseline -->
    <line x1="55" y1="315" x2="182" y2="315" stroke="#1e3a5f" stroke-width="1" />

    <!-- Line chart area -->
    <rect x="206" y="195" width="148" height="130" rx="6" fill="#0f1a2e" />
    <text x="214" y="211" fill="#64748b" font-size="8" font-family="system-ui,sans-serif">User Retention Trend</text>
    <polyline
      class="line-draw"
      points="220,305 238,290 256,295 274,272 292,278 310,258 328,242 338,235"
      fill="none"
      stroke="#34d399"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
    <circle class="dot-pulse" cx="338" cy="235" r="5" fill="#34d399" filter="url(#glow-blue)" />
    <!-- Grid lines -->
    <line x1="214" y1="275" x2="348" y2="275" stroke="#1e3a5f" stroke-width="1" stroke-dasharray="4,3" />
    <line x1="214" y1="315" x2="348" y2="315" stroke="#1e3a5f" stroke-width="1" />

    <!-- Bottom table-ish section -->
    <rect x="48" y="340" width="304" height="90" rx="6" fill="#0f1a2e" />
    <text x="56" y="357" fill="#64748b" font-size="8" font-family="system-ui,sans-serif">Top Performing Segments</text>
    <!-- Rows -->
    <rect x="56" y="365" width="120" height="7" rx="2" fill="#1e3a5f" />
    <rect x="185" y="365" width="55" height="7" rx="2" fill="#38bdf8" opacity="0.7" />
    <rect x="248" y="365" width="88" height="7" rx="2" fill="#0f1a2e" />
    <text x="336" y="372" fill="#34d399" font-size="7" font-family="system-ui,sans-serif">+24%</text>

    <rect x="56" y="381" width="90" height="7" rx="2" fill="#1e3a5f" />
    <rect x="185" y="381" width="40" height="7" rx="2" fill="#818cf8" opacity="0.7" />
    <rect x="248" y="381" width="88" height="7" rx="2" fill="#0f1a2e" />
    <text x="336" y="388" fill="#34d399" font-size="7" font-family="system-ui,sans-serif">+17%</text>

    <rect x="56" y="397" width="110" height="7" rx="2" fill="#1e3a5f" />
    <rect x="185" y="397" width="70" height="7" rx="2" fill="#34d399" opacity="0.6" />
    <rect x="248" y="397" width="88" height="7" rx="2" fill="#0f1a2e" />
    <text x="336" y="404" fill="#f59e0b" font-size="7" font-family="system-ui,sans-serif">+11%</text>

    <rect x="56" y="413" width="75" height="7" rx="2" fill="#1e3a5f" />
    <rect x="185" y="413" width="30" height="7" rx="2" fill="#38bdf8" opacity="0.5" />
    <rect x="248" y="413" width="88" height="7" rx="2" fill="#0f1a2e" />
    <text x="336" y="420" fill="#34d399" font-size="7" font-family="system-ui,sans-serif">+9%</text>
  </g>
</svg>
