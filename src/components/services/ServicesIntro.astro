---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import splashImg from "@/assets/images/splash.png";

interface Props {
  class?: string;
}

const { class: className } = Astro.props as Props;

const highlights = [
  "Data warehouse design and modeling (Snowflake, BigQuery, Redshift)",
  "dbt transformation layers — tested, documented, production-ready",
  "Power BI and Tableau dashboards built for real adoption",
  "ETL/ELT pipeline engineering in Python and Airflow",
  "BI team leadership and analytics governance frameworks",
  "Stakeholder alignment and KPI strategy from zero",
];
---

<section class:list={["py-20 md:pt-32", className]}>
  <div class="site-container grid gap-8 md:grid-cols-2 md:gap-16 items-center">

    <!-- Left: dashboard illustration -->
    <div class="relative flex items-center justify-center">
      <Image
        src={splashImg}
        alt="Data analytics dashboard preview"
        width={600}
        class="w-full max-h-[500px] object-contain rounded-xl md:rounded-2xl opacity-90"
      />
      <div class="absolute -top-8 left-[62%] -translate-x-1/2">
        <Icon name="tabler/chart-dots" class="text-primary-400 size-20 drop-shadow-2xl opacity-80" />
      </div>
    </div>

    <!-- Right: copy -->
    <div>
      <h2 class="h1">From Raw Data to Real Decisions.</h2>
      <p class="text-muted-foreground mt-3 max-w-lg text-pretty md:text-lg">
        Most organizations have data. Few have the infrastructure to trust it, the models to make sense of it, or the dashboards to act on it. I build all three — end to end, from the warehouse to the boardroom. Whether you need a single dashboard or a full modern data stack, I can scope it, build it, and hand it off with documentation your team can actually maintain.
      </p>

      <ul class="mt-8 space-y-3">
        {
          highlights.map((item) => (
            <li class="flex items-start">
              <span class="bg-primary-accent mt-1.5 mr-3 inline-block size-3 shrink-0 rounded-full md:mt-2" />
              <span class="text-muted-foreground md:text-lg">{item}</span>
            </li>
          ))
        }
      </ul>
    </div>

  </div>
</section>
