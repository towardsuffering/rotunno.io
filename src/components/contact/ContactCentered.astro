---
import ContactForm from "@/components/forms/ContactFormTwoCol.astro";
import { getLocaleFromUrl } from "@/js/localeUtils";
import { getLocalizedRoute, getTranslatedData, useTranslations } from "@/js/translationUtils";
const currLocale = getLocaleFromUrl(Astro.url);
const t = useTranslations(currLocale);
---

<section id="contact" class="site-container scroll-mt-20 py-12">
  <div class="mx-auto max-w-3xl">
    <div class="text-center" data-reveal="pop">
      <h2 class="h1">Get in Touch</h2>
      <p class="description mx-auto mt-4 mb-8 max-w-xl">Looking to hire, collaborate, or just talk data? I'd love to hear from you. I respond within one business day.</p>
    </div>

    <div class="mx-auto max-w-2xl rounded-xl border p-8 text-left shadow-md" data-reveal="rise" data-reveal-delay="0.2">
      <h3 class="font-heading mb-6 text-2xl font-semibold">Send a Message</h3>
      <ContactForm />
    </div>
  </div>
</section>
