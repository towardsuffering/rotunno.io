---
import ContactForm from "@/components/forms/ContactFormTwoCol.astro";
import { getLocaleFromUrl } from "@/js/localeUtils";
import { getLocalizedRoute, getTranslatedData, useTranslations } from "@/js/translationUtils";
const currLocale = getLocaleFromUrl(Astro.url);
const t = useTranslations(currLocale);
---

<section id="contact" class="site-container scroll-mt-20 py-12">
  <div class="mx-auto max-w-3xl">
    <div class="text-center" data-reveal="pop">
      <h2 class="h1">Let's Put Data to Work</h2>
      <p class="description mx-auto mt-4 mb-8 max-w-xl">Got a pipeline that's held together with duct tape and prayers? A dashboard nobody trusts? A warehouse migration that keeps getting deprioritized? That's exactly where I come in. Tell me what's broken — or what you're trying to build.</p>
    </div>

    <!-- Row 1: Form + Stripe side by side -->
    <div class="mx-auto grid max-w-5xl gap-8 md:grid-cols-2 items-start">
      <!-- Drop Me a Line -->
      <div class="rounded-xl border p-8 text-left shadow-md" data-reveal="rise" data-reveal-delay="0.2">
        <h3 class="font-heading mb-6 text-2xl font-semibold">Drop Me a Line</h3>
        <ContactForm />
      </div>

      <!-- Support My Work -->
      <div class="rounded-xl border p-8 text-center shadow-md flex flex-col items-center justify-center gap-5" data-reveal="rise" data-reveal-delay="0.35">
        <h3 class="font-heading text-2xl font-semibold">Support My Work</h3>
        <p class="text-muted-foreground text-sm max-w-xs">If my content, tools, or code have helped you — consider paying it forward.</p>
        <script async src="https://js.stripe.com/v3/buy-button.js"></script>
        <stripe-buy-button
          buy-button-id="buy_btn_1TbMCNKf3i8bH4sDF2dcukJP"
          publishable-key="pk_live_51QqPjYKf3i8bH4sDSbhHSoTfe77T8kdWEZnNWmw86Nl1Xkp1BSJMEBwig0tGrXDAiD6yf4DnCXXnBwafi7VsrIOM00PkkbOpqV"
        ></stripe-buy-button>
      </div>
    </div>

    <!-- Row 2: Calendly full width -->
    <div class="mx-auto mt-8 max-w-5xl rounded-xl border shadow-md" data-reveal="rise" data-reveal-delay="0.5">
      <div class="px-8 pt-8 pb-4 text-center">
        <h3 class="font-heading text-2xl font-semibold">Book a Call</h3>
        <p class="description mt-2">Pick a time that works and let's talk.</p>
      </div>
      <div class="calendly-inline-widget w-full" data-url="https://calendly.com/chrisrotunno-_my2/30min" style="min-width:320px;height:1000px;"></div>
      <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
    </div>
  </div>
</section>
