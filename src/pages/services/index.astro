---
export const prerender = true;
import AboutNumbers from "@/components/about/AboutNumbers.astro";
import Contact from "@/components/contact/Contact.astro";
import ServicesCards from "@/components/services/ServicesCards.astro";
import ServicesIntro from "@/components/services/ServicesIntro.astro";
import { getLocaleFromUrl } from "@/js/localeUtils";
import { getTranslatedData } from "@/js/translationUtils";
import BaseLayout from "@/layouts/BaseLayout.astro";

const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);
---

<BaseLayout
  title="Capabilities — Chris Rotunno"
  description="Data engineering, BI dashboard design, data warehouse architecture, and analytics strategy — end to end, from raw data to executive decisions."
>
  <ServicesIntro class="mt-8" />
  <ServicesCards />
  <AboutNumbers />
  <Contact />
</BaseLayout>
